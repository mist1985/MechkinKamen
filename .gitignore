node_modules/
.DS_Store

# Generated by scripts/build-www.mjs on every sync.
www/

# Android build output. The android/ project itself IS committed — it holds the
# manifest and MainActivity changes — but its build artefacts are not.
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/app/release/
android/capacitor-cordova-android-plugins/

# Signing material. A leaked keystore lets someone ship an update as you.
# Back it up somewhere safe and offline — never in git.
# The *keystore* globs are deliberately loose: an exact "*.jks" misses a file
# renamed to something like upload-keystore.jks.old, which is exactly how a
# discarded key nearly got committed once.
*.keystore*
*.jks*
*keystore*.properties
keystore.properties

# Local tester email list — personal addresses, never commit
testers.csv
